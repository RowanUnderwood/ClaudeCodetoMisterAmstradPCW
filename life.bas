1050 DATA "GLIDER",1,1,5, 0,1, 1,2, 2,0, 2,1, 2,2
1060 DATA "LWSS",6,2,9, 0,1, 0,4, 1,0, 2,0, 2,4, 3,0, 3,1, 3,2, 3,3
1070 DATA "RPENTO",6,18,5, 0,1, 0,2, 1,0, 1,1, 2,1
