10 REM --- Conway's Game of Life: random pattern, runs forever (Mallard BASIC) ---
20 DEFINT A-Z
30 GW=39 : GH=14
40 DIM A(GH,GW),B(GH,GW)
50 ESC$=CHR$(27) : RW$=SPACE$(GW*2)
60 RANDOMIZE {{SEED}}
70 REM -- pick a random pattern from the DATA library and seed the grid --
80 RESTORE : READ NP
90 P=INT(RND*NP)
100 FOR K=0 TO NP-1
110 READ NM$,BR,BC,NC
120 IF K=P THEN SEL$=NM$
130 FOR J=1 TO NC
140 READ RR,CC
150 IF K=P THEN A(BR+RR,BC+CC)=1
160 NEXT J
170 NEXT K
180 G=0
190 REM === infinite main loop ===
200 PRINT ESC$;"E";ESC$;"H";
210 FOR R=0 TO GH-1
220 FOR C=0 TO GW-1
230 IF A(R,C)=1 THEN MID$(RW$,C*2+1,2)="[]" ELSE MID$(RW$,C*2+1,2)="  "
240 NEXT C
250 PRINT RW$
260 NEXT R
270 PRINT "GEN ";G;"  PATTERN: ";SEL$;
280 LR=GH+1 : LC=0 : GOSUB 900
290 PRINT "THINKING ";
300 REM -- compute next generation (toroidal); bar grows one '#' per row --
310 FOR R=0 TO GH-1
320 FOR C=0 TO GW-1
330 N=-A(R,C)
340 FOR DR=-1 TO 1
350 RR=(R+DR+GH) MOD GH
360 FOR DC=-1 TO 1
370 CC=(C+DC+GW) MOD GW
380 N=N+A(RR,CC)
390 NEXT DC
400 NEXT DR
410 B(R,C)=0
420 IF A(R,C)=1 AND (N=2 OR N=3) THEN B(R,C)=1
430 IF A(R,C)=0 AND N=3 THEN B(R,C)=1
440 NEXT C
450 PRINT "#";
460 NEXT R
470 FOR R=0 TO GH-1
480 FOR C=0 TO GW-1
490 A(R,C)=B(R,C)
500 NEXT C
510 NEXT R
520 G=G+1
530 GOTO 200
900 PRINT ESC$;"Y";CHR$(LR+32);CHR$(LC+32); : RETURN
1000 DATA 8
