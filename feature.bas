10 REM --- Mallard BASIC feature test ---
20 DEFINT I-N
30 ESC$=CHR$(27)
40 PRINT ESC$;"E";ESC$;"H";
50 PRINT "MALLARD FEATURE TEST"
60 PRINT STRING$(20,"-")
70 REM -- FOR/STEP + SQR + PRINT USING --
80 FOR I=1 TO 5 STEP 2
90 PRINT USING "N=## SQR=#.###";I,SQR(I)
100 NEXT I
110 REM -- user function --
120 DEF FNC(X)=X*X+1
130 PRINT "FNC(4)=";FNC(4)
140 REM -- WHILE/WEND countdown --
150 N=3
160 WHILE N>0
170 PRINT "TICK ";N
180 N=N-1
190 WEND
200 REM -- string functions --
210 A$="mallard"
220 PRINT "UC=";UPPER$(A$);" LEN=";LEN(A$)
230 PRINT "MID=";MID$(A$,2,3)
240 REM -- READ/DATA sum --
250 T=0
260 FOR I=1 TO 4
270 READ V
280 T=T+V
290 NEXT I
300 PRINT "SUM=";T
310 DATA 10,20,30,40
320 REM -- GOSUB + MOD --
330 N=17
340 GOSUB 400
350 PRINT "ALL-DONE-42"
360 END
400 REM subroutine: odd/even test
410 IF N MOD 2=0 THEN PRINT N;"EVEN" ELSE PRINT N;"ODD"
420 RETURN
